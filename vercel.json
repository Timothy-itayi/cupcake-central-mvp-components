{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --prefix shopify-proto",
  "buildCommand": "npm run build --prefix shopify-proto",
  "outputDirectory": "shopify-proto/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
